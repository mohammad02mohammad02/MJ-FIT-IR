body{
    margin:0;
    background:#000;
    color:white;
    font-family:tahoma;
    text-align:center;
}

header{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
}

.logo{
    font-size:100px;
    font-weight:bold;
    color:#d4af37;
}

h1,h2{
    color:#d4af37;
}

p{
    font-size:20px;
    color:#ccc;
}

.btn{
    margin-top:30px;
    padding:15px 40px;
    background:#d4af37;
    color:#000;
    border-radius:30px;
    text-decoration:none;
    font-weight:bold;
}

section{
    padding:60px 20px;
}

.gallery{
    background:#111;
}

.box{
    display:inline-flex;
    width:250px;
    height:300px;
    margin:15px;
    background:#222;
    align-items:center;
    justify-content:center;
    border-radius:20px;
    color:#777;
}

footer{
    padding:30px;
    border-top:1px solid #333;
}
